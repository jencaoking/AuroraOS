# CONFIG_BOARD_LM3S6965_QB is not set
# CONFIG_BOARD_MIBAND8 is not set
# CONFIG_BOARD_QEMU_RV32_VIRT is not set
CONFIG_BOARD_NUCLEO_L031K6=y
CONFIG_BOARD="nucleo_l031k6"

#
# System Core Configuration
#
CONFIG_SCHEDULER=y
CONFIG_MAX_TASKS=4
CONFIG_TICK_RATE_HZ=1000
CONFIG_NO_DYNAMIC_ALLOCATION=y
# end of System Core Configuration

#
# File Systems
#
CONFIG_VFS=y
CONFIG_FS_RAMFS=y
CONFIG_FS_PROCFS=y
# end of File Systems

#
# Device Drivers
#
CONFIG_DEVICE_UART=y
CONFIG_TIMER_MANAGER=y
CONFIG_WORK_QUEUE=y
# end of Device Drivers

#
# Networking
#
# CONFIG_NETWORKING is not set
# end of Networking
# end of Networking

#
# Applications and runtimes
#
# CONFIG_LUA_VM is not set
# end of Applications and runtimes
