    bool is_valid;
};
# 7 "J:/PROJECT/auroraOS/drivers/input/touch_driver.hpp" 2



class TouchDriver : public CharDevice {
private:
    uint16_t max_x_;
    uint16_t max_y_;


    uint16_t sim_x_;
    uint16_t sim_y_;
    int sim_step_;
    bool sim_active_;
    int sim_dx_;
    int sim_dy_;

public:
    TouchDriver(const char* name, uint16_t max_x = 128, uint16_t max_y = 128)
        : CharDevice(name), max_x_(max_x), max_y_(max_y),
          sim_x_(100), sim_y_(64), sim_step_(0), sim_active_(true),
          sim_dx_(-4), sim_dy_(0) {}

    int open() override {

        return 0;
    }




    int read(char* buf, int len, int offset, void* priv) override {
        if (len < static_cast<int>(sizeof(TouchPoint))) return 0;

        TouchPoint* point = reinterpret_cast<TouchPoint*>(buf);

        static uint32_t frame_count = 0;
        frame_count++;


        if (!sim_active_ && (frame_count % 150 == 0)) {
            sim_active_ = true;
            sim_step_ = 0;
            static int gesture_cycle = 0;
            gesture_cycle = (gesture_cycle + 1) % 4;

            if (gesture_cycle == 0 || gesture_cycle == 1) {

                sim_x_ = 100;
                sim_y_ = 64;
                sim_dx_ = -4;
                sim_dy_ = 0;
            } else {

                sim_x_ = 20;
                sim_y_ = 64;
                sim_dx_ = 4;
                sim_dy_ = 0;
            }
        }

        if (sim_active_) {
            point->x = sim_x_;
            point->y = sim_y_;

            if (sim_step_ == 0) {
                point->state = TouchState::PRESSED;
            } else if (sim_step_ < 20) {
                point->state = TouchState::MOVING;
                sim_x_ += sim_dx_;
                sim_y_ += sim_dy_;
            } else {
                point->state = TouchState::RELEASED;
                sim_active_ = false;
            }
            point->is_valid = true;
            sim_step_++;
        } else {
            point->is_valid = false;
        }

        return sizeof(TouchPoint);
    }
};
