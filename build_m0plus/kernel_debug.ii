class St7789Driver {
private:
    uint16_t width_;
    uint16_t height_;
    bool is_sleeping_;
    uint8_t current_brightness_;


    void set_dc_pin(bool data) {
        volatile uint32_t* gpio_wt_en = reinterpret_cast<uint32_t*>((0x40010000 + 0x04));
        volatile uint32_t* gpio_wt_dis = reinterpret_cast<uint32_t*>((0x40010000 + 0x08));
        if (data) {
            *gpio_wt_en = (1 << 12);
        } else {
            *gpio_wt_dis = (1 << 12);
        }
    }

    void spi_transmit_byte(uint8_t byte) {
        volatile uint32_t* iom_fifo = reinterpret_cast<uint32_t*>((0x50004000 + 0x200));
        volatile uint32_t* iom_cmd = reinterpret_cast<uint32_t*>((0x50004000 + 0x108));
        volatile uint32_t* iom_status = reinterpret_cast<uint32_t*>((0x50004000 + 0x104));

        *iom_fifo = byte;
        *iom_cmd = 0x1;
        uint32_t timeout = 1000000;
        while ((*iom_status & 0x1) != 0 && --timeout);
    }

    void spi_send_cmd(uint8_t cmd) {
        set_dc_pin(false);
        spi_transmit_byte(cmd);
    }

    void spi_send_data(uint8_t data) {
        set_dc_pin(true);
        spi_transmit_byte(data);
    }

    void spi_send_data_16(uint16_t data) {
        set_dc_pin(true);
        spi_transmit_byte(data >> 8);
        spi_transmit_byte(data & 0xFF);
    }

    St7789Driver() : width_(192), height_(490), is_sleeping_(false), current_brightness_(100) {}

public:
    static St7789Driver& instance() {
        static St7789Driver driver;
        return driver;
    }




    void init() {





        spi_send_cmd(0x01);


        spi_send_cmd(0x11);




        spi_send_cmd(0x29);
        set_brightness(100);
        is_sleeping_ = false;
    }






    void enter_sleep() {
        if (is_sleeping_) return;
        spi_send_cmd(0x28);
        spi_send_cmd(0x10);
        is_sleeping_ = true;
    }


    void exit_sleep() {
        if (!is_sleeping_) return;
        spi_send_cmd(0x11);

        spi_send_cmd(0x29);
        is_sleeping_ = false;
    }


    void set_brightness(uint8_t level) {
        if (level > 100) level = 100;
        current_brightness_ = level;


        uint8_t hw_val = (level * 255) / 100;
        spi_send_cmd(0x51);
        spi_send_data(hw_val);
    }


    void set_low_brightness() {
        set_brightness(30);
    }






    void set_window(uint16_t x0, uint16_t y0, uint16_t x1, uint16_t y1) {
        spi_send_cmd(0x2A);
        spi_send_data_16(x0);
        spi_send_data_16(x1);

        spi_send_cmd(0x2B);
        spi_send_data_16(y0);
        spi_send_data_16(y1);

        spi_send_cmd(0x2C);
    }


    void write_patch(const uint16_t* buffer, uint32_t pixel_count) {
        if (is_sleeping_ || pixel_count == 0) return;

        set_dc_pin(true);






        volatile uint32_t* dma_cfg = reinterpret_cast<uint32_t*>((0x50004000 + 0x2A0));
        volatile uint32_t* dma_targ = reinterpret_cast<uint32_t*>((0x50004000 + 0x2A4));
        volatile uint32_t* dma_totlen = reinterpret_cast<uint32_t*>((0x50004000 + 0x2A8));
        volatile uint32_t* iom_status = reinterpret_cast<uint32_t*>((0x50004000 + 0x104));

        *dma_targ = static_cast<uint32_t>(reinterpret_cast<uintptr_t>(buffer));
        *dma_totlen = pixel_count * 2;
        *dma_cfg = 0x1;



        uint32_t timeout = 5000000;
        while ((*iom_status & 0x2) == 0 && --timeout) {
            __asm__ volatile ("wfi" : : : "memory");
        }
    }

    uint16_t get_width() const { return width_; }
    uint16_t get_height() const { return height_; }
};
