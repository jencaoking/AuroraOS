class UartDevice : public CharDevice {
private:
    Mutex tx_mutex_;

public:

    UartDevice(const char* name) : CharDevice(name) {}


    int open() override {

        return 0;
    }

    int close() override {
        return 0;
    }


    int write(const char* buf, int len, int offset, void* priv) override {
        (void)offset;
        LockGuard lock(tx_mutex_);
        return write_internal(buf, len);
    }

    int write_internal(const char* buf, int len) {
        for (int i = 0; i < len; i++) {

            if (buf[i] == '\n') {
                uart_putc('\r');
            }
            uart_putc(buf[i]);
        }
        return len;
    }


    int read(char* buf, int len, int offset, void* priv) override {
        (void)offset;
        int bytes_read = 0;


        while (bytes_read < len - 1) {
            char c;
            if (uart_getc_nb(&c)) {
                if (c == '\r' || c == '\n') {
                    buf[bytes_read] = '\0';
                    write_internal("\n", 1);
                    break;
                } else if (c == '\b' || c == 127) {
                    if (bytes_read > 0) {
                        bytes_read--;

                        write_internal("\b \b", 3);
                    }
                } else {
                    buf[bytes_read++] = c;
                    write_internal(&c, 1);
                }
            } else {

                sys_sleep(5);
            }
        }
        return bytes_read;
    }
};
