    EV_KEY = 0x01,
    EV_ABS = 0x03
};


enum class TouchState : uint8_t {
    IDLE = 0,
    PRESSED = 1,
    MOVING = 2,
    RELEASED = 3
};


struct InputEvent {
    uint32_t timestamp;
    InputEventType type;
    uint16_t code;
    int32_t value;
};


